generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

  model License {
  id          String   @id @default(uuid())
  machineCode String
  product     String   @default("stark-tube")
  version     Int      @default(1)
  iat         Int
  exp         Int
  payloadJson String
  signature   String
  licenseKey  String
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
}
